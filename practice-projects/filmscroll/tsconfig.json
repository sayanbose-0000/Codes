{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "src/",
    "paths": {
      "~/*": ["./*"],
      "@/*": ["../*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "tailwind.config.js",
    "metro.config.js",
    "babel.config.js",
    "nativewind-env.d.ts"
  ]
}
